{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "concept.json",
  "title": "Curriculum Concepts",
  "description": "Schema for concepts.json — the full hierarchical curriculum map of phases, topics, and subtopics",
  "type": "object",
  "required": ["title", "description", "phases"],
  "additionalProperties": false,
  "properties": {
    "title": { "type": "string" },
    "description": { "type": "string" },
    "phases": {
      "type": "array",
      "items": { "$ref": "#/definitions/phase" }
    }
  },
  "definitions": {
    "priority": {
      "type": "string",
      "enum": ["P1", "P2", "P3"],
      "description": "P1 = critical/foundational, P2 = important, P3 = advanced/specialization"
    },
    "node": {
      "type": "object",
      "description": "A topic or subtopic — may contain further nested subtopics",
      "required": ["id", "title"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "description": "Snake_case identifier — shared with progress.json keys and concepts_dir folder names",
          "pattern": "^[a-z0-9]+(_[a-z0-9]+)*$"
        },
        "title": {
          "type": "string",
          "description": "Human-readable label for this topic or subtopic"
        },
        "priority": { "$ref": "#/definitions/priority" },
        "subtopics": {
          "type": "array",
          "description": "Nested child nodes — can be leaf concepts or further groupings",
          "items": { "$ref": "#/definitions/node" }
        }
      }
    },
    "phase": {
      "type": "object",
      "description": "A top-level learning phase grouping related topics",
      "required": ["id", "title", "topics"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "description": "Snake_case phase identifier",
          "pattern": "^phase_[1-9][0-9]*$"
        },
        "title": {
          "type": "string",
          "description": "Human-readable phase name"
        },
        "topics": {
          "type": "array",
          "description": "Top-level topics within this phase",
          "items": { "$ref": "#/definitions/node" }
        }
      }
    }
  }
}
