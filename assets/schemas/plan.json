{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "plan.json",
  "title": "Learning Plan",
  "description": "Schema for plan.json — phase ordering, durations, and prerequisites",
  "type": "object",
  "required": ["title", "description", "total_duration", "phases"],
  "additionalProperties": false,
  "properties": {
    "title": { "type": "string" },
    "description": { "type": "string" },
    "total_duration": {
      "type": "string",
      "description": "Overall estimated duration across all phases (e.g. '18–24 weeks')"
    },
    "phases": {
      "type": "array",
      "items": { "$ref": "#/definitions/phase" },
      "minItems": 1
    }
  },
  "definitions": {
    "phase": {
      "type": "object",
      "required": ["id", "title", "duration_weeks", "order", "prerequisites"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "description": "Snake_case phase identifier matching concepts.json (e.g. 'phase_1')",
          "pattern": "^phase_[1-9][0-9]*$"
        },
        "title": {
          "type": "string",
          "description": "Human-readable phase name"
        },
        "duration_weeks": {
          "type": "string",
          "description": "Estimated duration as a range or fixed value (e.g. '2–3', '4+', '3')"
        },
        "order": {
          "type": "integer",
          "description": "1-based sequence position — determines the intended study order",
          "minimum": 1
        },
        "prerequisites": {
          "type": "array",
          "description": "Phase IDs that must be completed before starting this phase",
          "items": {
            "type": "string",
            "pattern": "^phase_[1-9][0-9]*$"
          },
          "uniqueItems": true
        }
      }
    }
  }
}
